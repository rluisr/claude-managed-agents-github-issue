{
  "files": {
    "includes": ["src/**/*.ts", "src/**/*.tsx", "tailwind.config.ts", "package.json"]
  },
  "vcs": {
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["test/e2e/prompts.e2e.flow.js", "test/e2e/prompts.e2e.degradation.js"],
      "formatter": { "enabled": false },
      "linter": { "enabled": false }
    }
  ]
}
