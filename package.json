{
  "name": "github-issue",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "github-issue": "./index.ts"
  },
  "scripts": {
    "start": "bun run index.ts",
    "dev": "bun run --watch index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "bun test",
    "build": "bun run build:css",
    "build:css": "tailwindcss -i ./src/features/dashboard/styles/tailwind.css -o ./dist/dashboard.css --minify",
    "dev:css": "tailwindcss -i ./src/features/dashboard/styles/tailwind.css -o ./dist/dashboard.css --watch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "hono": "^4.12.14",
    "octokit": "^5.0.0",
    "pino": "^9.0.0",
    "uuid": "^11.0.0",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.30.0",
    "@biomejs/biome": "^2.0.0",
    "@tailwindcss/cli": "^4.2.4",
    "@types/node": "^24.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "proper-lockfile": "^4.1.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.0",
    "write-file-atomic": "^7.0.0"
  }
}
